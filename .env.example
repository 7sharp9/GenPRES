# GenPRES Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is excluded from git (opt-in .gitignore).
# Do NOT commit .env with real values.

# Google Sheets data URL ID (required)
# Ask a team member for the production URL ID, or use the demo value below.
# Demo: 1IZ3sbmrM4W4OuSYELRmCkdxpN9SlBI-5TLSvXWhHVmA
GENPRES_URL_ID=<your-url-id>

# Logging level: 0=off, d=debug, i=info, w=warning, e=error
GENPRES_LOG=i

# Production mode: 0=demo (safe default), 1=production data
GENPRES_PROD=0

# Debug mode: 0=off, 1=on
GENPRES_DEBUG=1

# Password for reloading resources via the UI (required for reload to work)
# If not set, resource reload is disabled (fail-closed)
GENPRES_RELOAD_PASSWORD=<your-reload-password>
