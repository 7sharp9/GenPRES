<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateProgramFile>false</GenerateProgramFile>
    <WarnOn>3390;$(WarnOn)</WarnOn>
    <!-- temp fix for: https://github.com/fsprojects/Paket/issues/4307 -->
    <NoWarn>$(NoWarn);NU1510</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="FixtureJson.fs" />
    <Compile Include="Tests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>
  <!-- Offline round-trip fixtures (DoseRuleRoundtripTests), generated by
       Scripts/DownloadFixtures.fsx; copied next to the test dll so the test
       runs hermetically (no Google Sheets / cache / env). -->
  <ItemGroup>
    <Content Include="fixtures\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>fixtures\%(Filename)%(Extension)</Link>
    </Content>
    <None Include="Scripts\DownloadFixtures.fsx" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Informedica.GenFORM.Lib\Informedica.GenFORM.Lib.fsproj" />
  </ItemGroup>
  <Import Project="..\..\.paket\Paket.Restore.targets" />
</Project>